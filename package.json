{
  "name": "supership",
  "version": "0.1.0",
  "private": true,
  "description": "SuperShip monorepo - rebuilt Ship/Fleetgraph with a unified document model",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --recursive run dev",
    "dev:api": "pnpm --filter @supership/api dev",
    "dev:web": "pnpm --filter @supership/web dev",
    "build": "pnpm --recursive run build",
    "type-check": "pnpm --recursive run type-check",
    "test": "pnpm --recursive run test",
    "lint": "pnpm --recursive run lint",
    "clean": "pnpm --recursive run clean"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
